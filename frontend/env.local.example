# ==========================================
# 🔐 前端本地敏感配置模板
# ==========================================
# 使用说明：
# 1. 复制此文件并重命名为 .env.local
# 2. 将下面的占位符替换为你的真实配置
# 3. 重启开发服务器使配置生效
# 4. ⚠️ 切勿将 .env.local 提交到Git！
# ==========================================

# 开发环境 API 基础路径，保持 / 可走 Vite 代理
VITE_API_URL=/

# 开发环境代理目标后端
VITE_API_PROXY_URL=http://localhost:10003

# 其他敏感配置（如有需要）
# VITE_SOME_SECRET_KEY=<替换为你的密钥>
